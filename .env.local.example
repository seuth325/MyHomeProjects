# ── Clerk Authentication ────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (must match routes in your app)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/role-selection
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/role-selection

# Clerk webhook secret — from Clerk Dashboard → Webhooks → your endpoint → Signing Secret
# Configure the webhook to point at: https://yourdomain.com/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_...

# ── Database (Hostinger-managed MySQL) ──────────────────────────────────────────
# Get host/user/password/db name from hPanel > Databases > MySQL Databases
DATABASE_URL=mysql://username:password@localhost:3306/dbname

# ── UploadThing (file uploads) ───────────────────────────────────────────────────
# Get from https://uploadthing.com → your app → API Keys
UPLOADTHING_TOKEN=...

# ── Optional: AI bid recommendations ────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
