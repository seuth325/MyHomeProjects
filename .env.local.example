# ── Authentication (Auth.js — self-hosted, email/password) ──────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=change-me-generate-a-real-secret
# Not required for local dev over http://localhost, but harmless to set.
AUTH_TRUST_HOST=true

# ── Database (Hostinger-managed MySQL) ──────────────────────────────────────────
# Get host/user/password/db name from hPanel > Databases > MySQL Databases
DATABASE_URL=mysql://username:password@localhost:3306/dbname

# ── UploadThing (file uploads) ───────────────────────────────────────────────────
# Get from https://uploadthing.com → your app → API Keys
UPLOADTHING_TOKEN=...

# ── Optional: AI bid recommendations ────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
