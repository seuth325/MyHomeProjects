# Database (self-hosted PostgreSQL on the VPS)
# Used by docker-compose to create the Postgres container's superuser password.
POSTGRES_PASSWORD="change-me"
# When running via `docker compose up`, the app container reaches Postgres via
# the service name "db". For a bare (non-Docker) install on the VPS, use localhost.
DATABASE_URL="postgresql://fixmyhome:change-me@db:5432/fixmyhome"

# Clerk Authentication
# Webhook endpoint to configure in the Clerk dashboard: https://fixmyhome.pro/api/webhooks/clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/role-selection"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/role-selection"

# Uploadthing
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."

# AI (Optional - for bid recommendations)
ANTHROPIC_API_KEY="sk-ant-..."

# App Config
NEXT_PUBLIC_APP_URL="https://fixmyhome.pro"
NODE_ENV="production"
