# Database (Hostinger-managed MySQL — get these from hPanel > Databases)
MYSQL_PASSWORD="change-me"
DATABASE_URL="mysql://username:change-me@localhost:3306/dbname"

# Authentication (Auth.js — self-hosted, email/password)
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="change-me-generate-a-real-secret"
# Required on non-Vercel hosts (Auth.js's default host-trust check assumes Vercel)
AUTH_TRUST_HOST="true"
AUTH_URL="https://fixmyhome.pro"

# Uploadthing
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."

# AI (Optional - for bid recommendations)
ANTHROPIC_API_KEY="sk-ant-..."

# App Config
NEXT_PUBLIC_APP_URL="https://fixmyhome.pro"
NODE_ENV="production"
